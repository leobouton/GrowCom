// ============================================================
// PRISMA SCHEMA — GrowCom
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- Enums ---

enum UserRole {
  SUPER_ADMIN
  MANAGER
  TEAM_LEAD
  BU_MANAGER
  RECRUITER
  COMMERCIAL
}

enum TenantPlan {
  TRIAL
  STARTER
  PRO
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum CommissionRuleType {
  PERCENTAGE
  FIXED
  TIERED
}

enum DealStatus {
  OPEN
  WON
  LOST
}

enum DisputeStatus {
  OPEN
  RESOLVED_ACCEPTED
  RESOLVED_REJECTED
}

enum CommissionStatus {
  PENDING
  VALIDATED
  PAID
  CANCELLED
}

enum RuleScope {
  INDIVIDUAL
  TEAM
  GLOBAL
}

enum AssigneeType {
  INDIVIDUAL
  TEAM
}

enum ContestMetric {
  REVENUE
  DEAL_COUNT
  MARGIN
}

enum ContestStatus {
  ACTIVE
  ENDED
  CANCELLED
}

enum DealSource {
  ODOO
  FILE
}

enum ImportStatus {
  PENDING
  PROCESSING
  SUCCESS
  PARTIAL_ERROR
  FAILED
}

enum ImportBatchStatus {
  COMPLETED
  CANCELLED
  PARTIALLY_CANCELLED
}

enum ImportSource {
  CSV
  XLSX
}

// --- Models ---

model Tenant {
  id                     String       @id @default(cuid())
  name                   String
  slug                   String       @unique
  stripeCustomerId        String?      @unique
  stripeSubscriptionId    String?      @unique
  plan                   TenantPlan   @default(TRIAL)
  status                 TenantStatus @default(ACTIVE)
  odooUrl                    String?
  odooDatabase               String?
  odooLogin                  String?
  odooApiKey                 String?      // Stockée chiffrée (AES-256-GCM) via encryption.ts
  odooLimitWarningSentAt     DateTime?    // Date du dernier email d'alerte limite Odoo (throttle 2 jours)
  createdAt                  DateTime     @default(now())

  users               User[]
  groups              Group[]
  commissionRules     CommissionRule[]
  deals               Deal[]
  commissions         Commission[]
  auditLogs           AuditLog[]
  ruleAssignments     RuleAssignment[]
  contests            Contest[]
  importLogs          ImportLog[]
  importBatches       ImportBatch[]
  dealAssignments     DealAssignment[]
  objectiveSnapshots    ObjectiveSnapshot[]
  commissionAdjustments CommissionAdjustment[]
  commissionDisputes    CommissionDispute[]

  @@index([status])
  @@index([slug])
}

model Group {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  color     String   @default("#6366f1")
  leadId    String?
  managerId String?
  createdAt DateTime @default(now())

  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead    User?  @relation("GroupLead", fields: [leadId], references: [id], onDelete: SetNull)
  manager User?  @relation("GroupManager", fields: [managerId], references: [id], onDelete: SetNull)
  members User[] @relation("GroupMembers")

  @@index([tenantId])
  @@index([leadId])
  @@index([managerId])
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  passwordHash      String
  firstName         String
  lastName          String
  role              UserRole
  tenantId          String?
  groupId           String?
  fixedSalary       Float     @default(0) // Salaire fixe BRUT MENSUEL en euros
  objectives        Json      @default("[]")
  isActive          Boolean   @default(true)
  emailVerified     Boolean   @default(false)
  inviteToken        String?   @unique
  inviteTokenExpiry  DateTime?
  resetToken         String?   @unique
  resetTokenExpiry   DateTime?
  createdAt          DateTime  @default(now())

  tenant              Tenant?          @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  group               Group?           @relation("GroupMembers", fields: [groupId], references: [id], onDelete: SetNull)
  ledGroups           Group[]          @relation("GroupLead")
  managedGroups       Group[]          @relation("GroupManager")
  commissions         Commission[]
  createdRules        CommissionRule[] @relation("CreatedByUser")
  assignedDeals       Deal[]
  auditLogs           AuditLog[]
  refreshTokens       RefreshToken[]
  ruleAssignments     RuleAssignment[]
  createdContests     Contest[]        @relation("ContestCreator")
  importLogs          ImportLog[]      @relation("ImportLogUploader")
  dealAssignments       DealAssignment[]
  objectiveSnapshots    ObjectiveSnapshot[]
  commissionAdjustments CommissionAdjustment[]
  raisedDisputes        CommissionDispute[]    @relation("DisputeRaiser")

  @@index([tenantId])
  @@index([email])
  @@index([inviteToken])
  @@index([role])
  @@index([groupId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model CommissionRule {
  id               String             @id @default(cuid())
  tenantId         String
  name             String
  description      String
  type             CommissionRuleType
  config           Json
  scope            RuleScope          @default(GLOBAL)
  dealType         String?
  paymentDelayDays Int?
  isActive         Boolean            @default(true)
  isArchived       Boolean            @default(false)
  validatedAt      DateTime?
  createdBy        String
  createdAt        DateTime           @default(now())

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  creator     User             @relation("CreatedByUser", fields: [createdBy], references: [id])
  commissions Commission[]
  assignments RuleAssignment[]

  @@index([tenantId])
  @@index([tenantId, isArchived])
}

model RuleAssignment {
  id             String       @id @default(cuid())
  tenantId       String
  ruleId         String
  assignedToType AssigneeType
  userId         String?
  teamName       String?
  startDate      DateTime     @default(now())
  endDate        DateTime?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())

  tenant Tenant         @relation(fields: [tenantId], references: [id])
  rule   CommissionRule @relation(fields: [ruleId], references: [id])
  user   User?          @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([ruleId])
}

model Deal {
  id             String     @id @default(cuid())
  tenantId       String
  odooId         String?    // Uniquement pour les deals Odoo
  fileExternalId String?    // Uniquement pour les deals importés via fichier
  source         DealSource @default(ODOO)
  title          String
  clientName     String?
  amount         Float      @default(0)
  currency       String     @default("EUR")
  status         DealStatus @default(OPEN)
  probability    Float      @default(0)
  assignedToId   String?
  closedAt       DateTime?
  syncedAt       DateTime   @default(now())
  createdAt      DateTime   @default(now())
  dealType       String?
  notes          String?
  importLogId    String?
  costAmount     Float?     // Coût du deal (achat, sous-traitance, frais)
  marginAmount   Float?     // Marge réelle = amount - costAmount si calculée, ou importée directement
  marginSource   String?    // 'ODOO' | 'CSV_IMPORT' | 'COMPUTED' | null
  importBatchId  String?

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedTo  User?            @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  commissions Commission[]
  importLog   ImportLog?       @relation(fields: [importLogId], references: [id], onDelete: SetNull)
  importBatch ImportBatch?     @relation("ImportBatchDeals", fields: [importBatchId], references: [id], onDelete: SetNull)
  assignments DealAssignment[]

  @@unique([tenantId, odooId])
  @@unique([tenantId, fileExternalId])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([assignedToId])
  @@index([importLogId])
  @@index([importBatchId])
}

model Commission {
  id                   String           @id @default(cuid())
  tenantId             String
  userId               String
  dealId               String
  ruleId               String
  amount               Float
  status               CommissionStatus @default(PENDING)
  calculationDetail    String?
  calculatedAt         DateTime         @default(now())
  scheduledPaymentAt   DateTime?
  validatedAt          DateTime?
  paidAt               DateTime?
  cancelledAt          DateTime?
  cancelledBy          String?          // userId du manager qui a annulé (référence souple)
  cancellationReason   String?
  awaitingClientPayment Boolean         @default(false)
  clientPaidAt         DateTime?
  clientPaidBy         String?          // userId du manager qui a marqué le paiement client

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal     Deal           @relation(fields: [dealId], references: [id], onDelete: Cascade)
  rule     CommissionRule @relation(fields: [ruleId], references: [id])
  disputes CommissionDispute[]

  @@unique([dealId, userId, ruleId])
  @@index([tenantId])
  @@index([userId])
  @@index([tenantId, status])
  @@index([dealId])
}

model DealAssignment {
  id        String   @id @default(cuid())
  tenantId  String
  dealId    String
  userId    String
  share     Float    @default(1.0)  // Part en décimal (0.7 = 70%). Somme des shares d'un deal = 1.0
  role      String?  // Libre : "Hunter", "Closer", "SDR"... pour traçabilité
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([dealId, userId])
  @@index([tenantId])
  @@index([dealId])
  @@index([userId])
}

model Contest {
  id                    String        @id @default(cuid())
  tenantId              String
  name                  String
  description           String        @default("")
  prize                 String
  metric                ContestMetric
  scope                 RuleScope     @default(GLOBAL)
  teamName              String?
  participantIds        Json          @default("[]")
  periodStart           DateTime
  periodEnd             DateTime
  status                ContestStatus @default(ACTIVE)
  anonymousLeaderboard  Boolean       @default(false)
  createdBy             String
  createdAt             DateTime      @default(now())

  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  creator User   @relation("ContestCreator", fields: [createdBy], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
}

model ImportLog {
  id          String       @id @default(cuid())
  tenantId    String
  uploadedBy  String
  fileName    String
  status      ImportStatus @default(PENDING)
  totalRows   Int          @default(0)
  successRows Int          @default(0)
  errorRows   Int          @default(0)
  skippedRows Int          @default(0)
  errors      Json         @default("[]")
  pendingRows Json?        // Stockage temporaire des lignes validées avant confirmation (nettoyé après)
  createdAt   DateTime     @default(now())
  completedAt DateTime?

  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploader User   @relation("ImportLogUploader", fields: [uploadedBy], references: [id])
  deals    Deal[]

  @@index([tenantId])
  @@index([tenantId, createdAt])
}

model ImportBatch {
  id                  String            @id @default(cuid())
  tenantId            String
  importedBy          String
  source              ImportSource
  originalFileName    String?
  totalRows           Int
  createdRows         Int
  updatedRows         Int
  errorRows           Int
  status              ImportBatchStatus @default(COMPLETED)
  cancelledAt         DateTime?
  cancelledBy         String?
  cancellationReason  String?
  cancellationSummary Json?
  updatedDealSnapshots Json?
  importErrors        Json?
  createdAt           DateTime          @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deals  Deal[] @relation("ImportBatchDeals")

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([importedBy])
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  action    String
  entity    String
  entityId  String
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

model ObjectiveSnapshot {
  id           String   @id @default(cuid())
  tenantId     String
  userId       String
  objectiveId  String   // L'id de l'objectif (ou occurrence) au moment du snapshot
  periodLabel  String   // "Janvier 2026", "T1 2026", "Année 2026"
  snapshotData Json     // Copie complète de l'objectif
  actualValue  Float    // CA réel atteint sur la période
  bonusEarned  Float    // Prime gagnée selon les paliers/bonus
  snapshotAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([userId, snapshotAt])
}

model CommissionAdjustment {
  id                   String           @id @default(cuid())
  tenantId             String
  userId               String
  originalCommissionId String?          // Commission d'origine si clawback (référence souple, pas de FK)
  amount               Float            // Peut être négatif (clawback) ou positif (bonus exceptionnel)
  reason               String
  status               CommissionStatus @default(VALIDATED)
  createdBy            String           // userId du manager
  createdAt            DateTime         @default(now())
  paidAt               DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([originalCommissionId])
}

model CommissionDispute {
  id              String        @id @default(cuid())
  tenantId        String
  commissionId    String
  raisedBy        String        // userId du commercial qui conteste
  reason          String
  status          DisputeStatus @default(OPEN)
  managerResponse String?
  resolvedBy      String?
  resolvedAt      DateTime?
  createdAt       DateTime      @default(now())

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  commission Commission @relation(fields: [commissionId], references: [id], onDelete: Cascade)
  raiser     User       @relation("DisputeRaiser", fields: [raisedBy], references: [id])

  @@index([tenantId])
  @@index([commissionId])
  @@index([raisedBy])
  @@index([status])
}
